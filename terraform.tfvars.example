# Copie para terraform.tfvars (NAO versionado) e preencha com os seus valores,
# ou defina tudo via variaveis de ambiente TF_VAR_* / secrets do GitHub Actions.

subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "11111111-1111-1111-1111-111111111111"

location = "eastus2"

infra_resource_group_name  = "rg-infra-eastus2"
imagem_resource_group_name = "rg-imagem-eastus2"

vnet_name          = "vnet-infra-eastus2"
vnet_address_space = ["192.168.14.0/23", "10.172.28.0/22", "10.172.32.0/24"]

wan_subnet_prefix = "192.168.15.0/24"
lan_subnet_prefix = "10.172.31.0/24"
avd_subnet_prefix = "10.172.32.0/24"

nsg_wan_name = "nsg-wan-eastus2"
nsg_lan_name = "nsg-lan-eastus2"
nsg_avd_name = "nsg-avd-eastus2"

tags = {
  owner       = "antonyleiras"
  cost_center = "it"
}
