# Copie para terraform.tfvars (NAO versionado) e preencha com os seus valores,
# ou defina tudo via variaveis de ambiente TF_VAR_* / secrets do GitHub Actions.

subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "11111111-1111-1111-1111-111111111111"

location = "eastus2"

infra_resource_group_name  = "rg-infra-eastus2"
imagem_resource_group_name = "rg-imagem-eastus2"

vnet_name          = "vnet-infra-eastus2"
vnet_address_space = ["192.168.14.0/23", "10.172.28.0/22"]

wan_subnet_prefix = "192.168.15.0/24"
lan_subnet_prefix = "10.172.29.0/24"
avd_subnet_prefix = "10.172.30.0/24"

nsg_wan_name = "nsg-wan-eastus2"
nsg_lan_name = "nsg-lan-eastus2"
nsg_avd_name = "nsg-avd-eastus2"

route_table_lan_name = "rt-lan-eastus2"

# --- Firewall Mikrotik CHR (aslfwus2) ---
mikrotik_storage_account_name       = "stgacctaslinfraus2"
mikrotik_vhd_container_name         = "vhds"
mikrotik_vhd_blob_name              = "chr.vhd"
mikrotik_upload_principal_object_id = null # Object ID do SP do GitHub Actions (opcional)

deploy_mikrotik_firewall = false # so vire true depois do VHD estar no storage account

firewall_name                 = "aslfwus2"
firewall_vm_size              = "Standard_B2ats_v2"
firewall_disk_type            = "StandardSSD_LRS"
firewall_wan_private_ip       = "192.168.15.254"
firewall_lan_private_ip       = "10.172.29.254"
firewall_create_wan_public_ip = true

tags = {
  owner       = "antonyleiras"
  cost_center = "it"
}
